CLARKE_ENV=development
CLARKE_LOG_LEVEL=debug

# PostgreSQL
CLARKE_POSTGRES_URL=postgresql+asyncpg://clarke:clarke_dev@localhost:5432/clarke

# LLM
CLARKE_DEFAULT_ANSWER_MODEL=gpt-4o-mini
CLARKE_DEFAULT_ROUTER_MODEL=gpt-4o-mini
CLARKE_LITELLM_MASTER_KEY=
OPENAI_API_KEY=

# Telemetry
CLARKE_OTEL_ENDPOINT=http://localhost:4317
CLARKE_PHOENIX_ENDPOINT=http://localhost:6006

# Qdrant
CLARKE_QDRANT_HOST=localhost
CLARKE_QDRANT_PORT=6333
CLARKE_QDRANT_COLLECTION=clarke_chunks

# Embeddings
CLARKE_EMBEDDING_MODEL=text-embedding-3-small
CLARKE_EMBEDDING_DIMENSIONS=1536
CLARKE_CHUNK_SIZE_TOKENS=512
CLARKE_CHUNK_OVERLAP_TOKENS=64

# Retrieval
CLARKE_SEARCH_TOP_K=20
CLARKE_RERANK_TOP_K=5
CLARKE_RERANK_ENABLED=true
CLARKE_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Neo4j
CLARKE_NEO4J_URI=bolt://localhost:7687
CLARKE_NEO4J_USER=neo4j
CLARKE_NEO4J_PASSWORD=clarke_dev
CLARKE_NEO4J_DATABASE=neo4j
CLARKE_GRAPH_ENABLED=true
CLARKE_GRAPH_TRAVERSAL_MAX_HOPS=2
CLARKE_GRAPH_RETRIEVAL_TOP_K=10

# Broker policy
CLARKE_MAX_RETRIEVAL_LOOPS=1
CLARKE_MAX_SUBAGENT_DEPTH=5
CLARKE_MAX_ACTIVE_SUBAGENTS_PER_ROOT=10
CLARKE_DEFAULT_REQUEST_TIMEOUT_MS=800
